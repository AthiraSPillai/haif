{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://haif.dev/schema/haif-record.schema.json",
  "title": "HAIF Record",
  "type": "object",
  "required": ["type", "id", "title", "status", "owner", "created_by", "created_at", "updated_at"],
  "additionalProperties": true,
  "properties": {
    "type": {
      "type": "string",
      "enum": ["Signal", "Proposal", "Intent", "Design", "Decision", "Task", "Review", "Conflict", "AgentRun"]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-_.]*$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "tldr": {
      "type": "string",
      "minLength": 10,
      "description": "One or two sentence summary for human reviewers."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "proposed", "accepted", "reviewed", "approved", "in_progress", "blocked", "superseded", "rejected", "released"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created_by": {
      "type": "string",
      "enum": ["human", "agent", "system"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["draft", "reviewed", "canonical"]
    }
  }
}
